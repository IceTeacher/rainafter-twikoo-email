# 配置多个测试收件人，使用英文逗号分隔
EMAIL_TEST_RECIPIENTS=your_qq_email@example.com,your_gmail_email@gmail.com

# 测试邮件的发件人地址
EMAIL_TEST_FROM=Rainafter Mail Test <your_sender@example.com>

# SMTP 发信配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# 某些 SMTP 服务商需要强制启用 STARTTLS，可按需开启
SMTP_REQUIRE_TLS=false

# 可选：测试邮件标题前缀，便于在收件箱中区分
EMAIL_TEST_SUBJECT_PREFIX=[email-compat]

# 可选：每封测试邮件之间的延时，单位毫秒，默认 1000
EMAIL_TEST_SEND_DELAY_MS=1000
