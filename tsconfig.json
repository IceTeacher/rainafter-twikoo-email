{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "composite": false,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "strictNullChecks": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["./emails/*"]
    }
  },
  "include": ["emails/**/*", "test/**/*", "tsconfig.json", "emails/global.d.ts"],
  "exclude": ["node_modules", ".react-email"]
}
